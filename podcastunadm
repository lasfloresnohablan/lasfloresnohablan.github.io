    <script>
    document.addEventListener('DOMContentLoaded', () => {

        /* --- 1. TAB LOGIC --- */
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                document.querySelectorAll('.temporada').forEach(section => {
                    section.classList.remove('active');
                });
                document.querySelector('.' + tab.dataset.target).classList.add('active');
            });
        });

        /* --- 2. MODAL LOGIC --- */
        const modal = document.getElementById('modal');
        const modalIframe = modal.querySelector('iframe');
        const openHero = document.getElementById('openModalHero');
        const closeBtn = modal.querySelector('.close');

        // Function to open the modal with a specific video ID
        function openModal(videoId) {
            if (videoId) {
                modalIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
                modal.classList.add('active');
            }
        }

        // Function to close the modal and stop the video
        function closeModal() {
            modal.classList.remove('active');
            modalIframe.src = "";
        }

        // Bind the Hero "Reproducir" button to a default video (using the first episode)
        if (openHero) {
            openHero.addEventListener('click', () => openModal('Aot-V7c0RyQ'));
        }

        // Close modal events
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            // Close if clicking outside the video container
            if (e.target === modal) closeModal();
        });

        /* --- 3. GENERALIZED SLIDER LOGIC --- */
        const sliders = document.querySelectorAll('.slider-section');

        sliders.forEach(section => {
            const container = section.querySelector('.slider-container');
            const leftBtn = section.querySelector('.arrow-left');
            const rightBtn = section.querySelector('.arrow-right');
            const bulletsContainer = section.querySelector('.slider-bullets');
            const cards = section.querySelectorAll('.movie-card');

            if (!container) return; // Skip if no container found

            const scrollAmount = 300; // Adjust this to scroll more/less per click

            // Arrow click events
            if (leftBtn) {
                leftBtn.addEventListener('click', () => {
                    container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
                });
            }

            if (rightBtn) {
                rightBtn.addEventListener('click', () => {
                    container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
                });
            }

            // Bind movie cards to open the modal
            cards.forEach(card => {
                card.addEventListener('click', () => {
                    const videoId = card.getAttribute('data-video');
                    openModal(videoId);
                });
            });

            // Generate dynamic bullets based on card count
            if (bulletsContainer && cards.length > 0) {
                // Estimate the number of "pages" by dividing total cards by 3
                const numBullets = Math.ceil(cards.length / 3);

                for (let i = 0; i < numBullets; i++) {
                    const bullet = document.createElement('div');
                    bullet.classList.add('bullet');
                    if (i === 0) bullet.classList.add('active');

                    // Clicking a bullet jumps to that section
                    bullet.addEventListener('click', () => {
                        const scrollPos = (container.scrollWidth / numBullets) * i;
                        container.scrollTo({ left: scrollPos, behavior: 'smooth' });
                    });
                    bulletsContainer.appendChild(bullet);
                }

                // Update active bullet based on scroll position
                container.addEventListener('scroll', () => {
                    const scrollPos = container.scrollLeft;
                    const maxScroll = container.scrollWidth - container.clientWidth;

                    let activeIndex = 0;
                    if (maxScroll > 0) {
                        activeIndex = Math.round((scrollPos / maxScroll) * (numBullets - 1));
                    }

                    const bullets = bulletsContainer.querySelectorAll('.bullet');
                    bullets.forEach((b, idx) => {
                        if (idx === activeIndex) {
                            b.classList.add('active');
                        } else {
                            b.classList.remove('active');
                        }
                    });
                });
            }
        });

    });
    </script>
